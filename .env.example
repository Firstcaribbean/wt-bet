# Server session secret. Generate a long random string and keep it stable in Vercel.
AUTH_SECRET=replace-me-with-a-long-random-string

# Optional. Free football-data.org API token for live football fixtures.
FOOTBALL_DATA_API_TOKEN=

# Firebase Web App config from Project settings -> General -> Your apps -> Firebase SDK snippet.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional analytics id from the same Firebase web app config.
VITE_FIREBASE_MEASUREMENT_ID=
